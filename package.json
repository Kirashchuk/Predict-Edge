{
  "name": "predict-edge",
  "version": "1.0.0",
  "private": true,
  "description": "On-chain prediction markets on Arc Testnet — Templars stack (Vite + React, Bun/Hono, Hardhat). Monorepo root scopes the Solidity contracts + deploy tooling; the frontend lives in app/, the backend in server/.",
  "scripts": {
    "dev:app": "cd app && bun run dev",
    "dev:api": "cd server && bun run dev",
    "build:app": "cd app && bun run build",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.ts --network arcTestnet",
    "deploy:clob": "hardhat run scripts/deploy-clob.ts --network arcTestnet",
    "verify-deploy": "node --no-warnings --experimental-strip-types scripts/verify-deploy.ts",
    "keeper": "node --no-warnings --experimental-strip-types scripts/keeper.ts",
    "generate-wallet": "node --no-warnings --experimental-strip-types scripts/generate-wallet.ts",
    "sync-env": "node --no-warnings --experimental-strip-types scripts/sync-env.ts",
    "test:contracts": "hardhat test",
    "reset": "node --no-warnings --experimental-strip-types scripts/reset-markets.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "@uma/core": "^2.62.2",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.0",
    "typescript": "^5"
  }
}
