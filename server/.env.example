# Hono-on-Bun backend for Predict-Edge.
# The backend reuses the repo-root .env.local written by the deploy script,
# so you normally don't need to fill these in separately.

# HTTP
API_PORT=8787
NODE_ENV=development
# Comma-separated allowed CORS origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173

# Chain (defaults to Arc Testnet public RPC)
ARC_RPC_URL=https://rpc.testnet.arc.network

# Deployer key + base UMA infra addresses (read from repo-root .env.local).
# PRIVATE_KEY=
# DEPLOY_FINDER_ADDRESS=
# DEPLOY_TIMER_ADDRESS=
