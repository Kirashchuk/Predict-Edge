# Vite frontend env (Templars stack). All client vars are VITE_-prefixed and
# read via import.meta.env. Contract addresses come from the deploy script
# (repo-root .env.local) — copy them here with the VITE_ prefix, or run the
# sync script: `bun run ../scripts/sync-env.ts`.

# Chain
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# Backend (Hono) base — proxied via Vite dev server at /v1
VITE_API_URL=http://localhost:8787

# Deployed contract addresses (from repo-root .env.local, VITE_-prefixed)
VITE_MARKET_ADDRESS=
VITE_AMM_ADDRESS=
VITE_CLOB_ADDRESS=
# Collateral = Arc Testnet native USDC ERC-20 (6 decimals, fixed system address)
VITE_USDC_ADDRESS=0x3600000000000000000000000000000000000000
VITE_OO_V2_ADDRESS=
VITE_FINDER_ADDRESS=
VITE_TIMER_ADDRESS=

# Circle modular wallets (optional — enables the Circle Passkey wallet option)
VITE_CIRCLE_CLIENT_KEY=
VITE_CIRCLE_CLIENT_URL=
